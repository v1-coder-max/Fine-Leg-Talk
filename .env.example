# ── Public vars (exposed to browser) ─────────────────────────────
# YouTube Data API key — protected by HTTP referrer restrictions in Google Cloud Console
NEXT_PUBLIC_YOUTUBE_API_KEY=your_youtube_api_key_here
NEXT_PUBLIC_YOUTUBE_CHANNEL_ID=your_channel_id_here

# Google Analytics 4
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Search Console verification
NEXT_PUBLIC_GSC_VERIFICATION=your_verification_code

# Site URL (used in canonical, OG tags, sitemap)
NEXT_PUBLIC_SITE_URL=https://fine-leg-talk.vercel.app

# ── Server-only secrets (NEVER expose to browser) ────────────────
# Admin password hash — generate with: node scripts/hash-password.js
ADMIN_PASSWORD_HASH=$2b$10$replace_with_generated_hash

# JWT secret — any long random string (at least 32 chars)
JWT_SECRET=replace_with_random_32_char_string

# GitHub repo settings — for committing blog posts from admin UI
GITHUB_TOKEN=ghp_replace_with_personal_access_token
GITHUB_REPO=v1-coder-max/Fine-Leg-Talk
GITHUB_BRANCH=main
